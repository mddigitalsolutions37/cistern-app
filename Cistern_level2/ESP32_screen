void drawProgressBar(int x, int y, int w, int h, float pct) {
  int innerX = x + 3;
  int innerY = y + 3;
  int innerW = w - 6;
  int innerH = h - 6;
  if (innerW < 1 || innerH < 1) return;

  float normalized = pct / 100.0f;
  if (normalized < 0.0f) normalized = 0.0f;
  if (normalized > 1.0f) normalized = 1.0f;
  int fillW = (int)(innerW * normalized);
  if (fillW < 0) fillW = 0;
  if (fillW > innerW) fillW = innerW;

  lcd.fillRoundRect(x, y, w, h, 12, COLOR_BG);
  lcd.drawRoundRect(x, y, w, h, 12, COLOR_BORDER);
  lcd.fillRoundRect(innerX, innerY, innerW, innerH, 10, COLOR_BLUE_DIM);
  if (fillW > 0) lcd.fillRoundRect(innerX, innerY, fillW, innerH, 10, COLOR_BLUE);
}

