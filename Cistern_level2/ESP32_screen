float pctFromDownFromTop(float tankHeightFt, int downFt, int downIn) {
  float down = (float)downFt + ((float)downIn / 12.0f);
  float depth = tankHeightFt - down;
  if (tankHeightFt <= 0.0f) return 0.0f;
  float pct = (depth / tankHeightFt) * 100.0f;
  if (pct < 0.0f) pct = 0.0f;
  if (pct > 100.0f) pct = 100.0f;
  return pct;
}

float galFromPct(float tankFullGal, float pct) {
  return (pct / 100.0f) * tankFullGal;
}

void refreshCalibrationPreview() {
  float pct = pctFromDownFromTop(calibTankHeightFt, calibDownFt, calibDownIn);
  float gal = galFromPct(calibTankFullGal, pct);
  calibPreviewMessage = "Preview: down " + String(calibDownFt) + "' " + String(calibDownIn) + "\" => " + String(pct, 1) + "% (~" + String((int)roundf(gal)) + " imp gal)";
}

String issueCalibrationCommand(const String& cmd) {
  if (!SCREEN_HC12_TX_ENABLED) {
    calibCommandResult = "Not sent: " + cmd + " (screen HC-12 is RX-only)";
    return calibCommandResult;
  }
  lastIssuedCommand = cmd;
  HC12Serial.print(cmd);
  HC12Serial.print('\n');   // PCB command parser expects newline-terminated commands.
  calibCommandResult = "Sent: " + cmd;
  return calibCommandResult;
}

void triggerSetupButtonHighlight(SetupCommandButton buttonId) {
  highlightedSetupButton = buttonId;
  setupButtonHighlightUntil = millis() + 180UL;
}

void runBaselineSaveAction() {
  calibBaselinePct = pctFromDownFromTop(calibTankHeightFt, calibDownFt, calibDownIn);
  calibBaselineTs = makeSavedTimestamp();
  saveCalibrationSettings();
  refreshCalibrationPreview();

  // Mirror the Flask app flow:
  // 1. save the baseline locally on the display
  // 2. clear remote calibration
  // 3. send SET_BASELINE <pct>
  issueCalibrationCommand("CLR_CAL");
  issueCalibrationCommand("SET_BASELINE " + String(calibBaselinePct, 1));
  calibResultMessage = SCREEN_HC12_TX_ENABLED
    ? "Baseline saved and pushed to remote board"
    : "Baseline saved locally; remote push skipped because display HC-12 is RX-only";
}

void toggleBaselineOverride() {
  calibForceBaseline = !calibForceBaseline;
  prefs.putBool("force_baseline", calibForceBaseline);
  calibResultMessage = String("Baseline Override: ") + (calibForceBaseline ? "ON" : "AUTO");
}

uint8_t detectGT911Address() {
  const uint8_t candidates[] = { GT911_ADDR_PRIMARY, GT911_ADDR_ALT };
  for (uint8_t addr : candidates) {
    Wire.beginTransmission(addr);
    if (Wire.endTransmission() == 0) return addr;
  }
  return 0;
}

String wifiStatusLabel() {
  wl_status_t status = WiFi.status();
  switch (status) {
    case WL_CONNECTED: return "Connected";
    case WL_CONNECT_FAILED: return "Connect Failed";
    case WL_CONNECTION_LOST: return "Connection Lost";
    case WL_DISCONNECTED: return "Disconnected";
    case WL_IDLE_STATUS: return "Idle";
    case WL_NO_SSID_AVAIL: return "SSID Not Found";
    default: return wifiConnectInProgress ? "Connecting..." : "Disconnected";
  }
}

