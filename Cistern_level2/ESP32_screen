void handleCalibEntryTouch() {
  if (pointInRect(touchX, touchY, CALIB_KEY_CANCEL)) {
    closeCalibEntry();
    return;
  }
  if (pointInRect(touchX, touchY, CALIB_KEY_CLEAR)) {
    calibEntryBuffer = "";
    lcd.startWrite();
    updateCalibEntryDisplay();
    lcd.endWrite();
    return;
  }
  if (pointInRect(touchX, touchY, CALIB_KEY_BKSP)) {
    if (calibEntryBuffer.length() > 0) {
      calibEntryBuffer.remove(calibEntryBuffer.length() - 1);
    }
    lcd.startWrite();
    updateCalibEntryDisplay();
    lcd.endWrite();
    return;
  }
  if (pointInRect(touchX, touchY, CALIB_KEY_APPLY)) {
    applyCalibEntry();
    return;
  }

  for (int row = 0; row < 4; ++row) {
    for (int col = 0; col < 3; ++col) {
      Rect r = calibKeyRect(row, col);
      if (!pointInRect(touchX, touchY, r)) continue;

      char key = calibKeyAt(row, col);
      if (key == '#') return;
      if (key == '.' && !calibEntryAllowsDecimal()) return;
      if (key == '.' && calibEntryBuffer.indexOf('.') >= 0) return;
      if (calibEntryBuffer.length() >= 10) return;

      calibEntryBuffer += key;
      lcd.startWrite();
      updateCalibEntryDisplay();
      lcd.endWrite();
      return;
    }
  }
}

// Header buttons are global navigation.
// Returning true stops the same touch from firing controls on the new page.
bool handleHeaderNavigation() {
  if (pointInRect(touchX, touchY, NAV_BTN_1)) {
    switch (currentPage) {
      case PAGE_DASHBOARD: setPage(PAGE_SETUP); break;
      case PAGE_SETUP: setPage(PAGE_DASHBOARD); break;
      case PAGE_WIFI: setPage(PAGE_DASHBOARD); break;
      case PAGE_WIFI_SELECT: setPage(PAGE_WIFI); break;
      case PAGE_WIFI_PASSWORD: setPage(PAGE_WIFI_SELECT); break;
    }
    return true;
  }

  if (pointInRect(touchX, touchY, NAV_BTN_2)) {
    switch (currentPage) {
      case PAGE_DASHBOARD: setPage(PAGE_WIFI); break;
      case PAGE_SETUP: setPage(PAGE_WIFI); break;
      case PAGE_WIFI: setPage(PAGE_SETUP); break;
      case PAGE_WIFI_SELECT: setPage(PAGE_DASHBOARD); break;
      case PAGE_WIFI_PASSWORD: setPage(PAGE_DASHBOARD); break;
    }
    return true;
  }
  return false;
}

