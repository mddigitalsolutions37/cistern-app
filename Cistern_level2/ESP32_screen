bool extractValue(const String& src, const String& key, String& out) {
  int start = src.indexOf(key);
  if (start < 0) return false;
  start += key.length();
  int end = src.indexOf(';', start);
  if (end < 0) end = src.length();
  out = src.substring(start, end);
  out.trim();
  return out.length() > 0;
}

bool parsePacket(const String& packet) {
  String val;
  bool gotAnything = false;

  if (extractValue(packet, "LVL:", val)) {
    levelPct = val.toFloat();
    gotAnything = true;
  }
  if (extractValue(packet, "G:", val)) {
    gallons = val.toInt();
    gotAnything = true;
  }
  if (extractValue(packet, "ADC:", val)) {
    adcValue = val.toInt();
    gotAnything = true;
  }
  if (extractValue(packet, "CAL:", val)) {
    calibrated = (val.toInt() != 0);
    gotAnything = true;
  }

  if (gotAnything) {
    if (levelPct < 0.0f) levelPct = 0.0f;
    if (levelPct > 100.0f) levelPct = 100.0f;
    if (gallons < 0) gallons = 0;
  }
  return gotAnything;
}

bool pointInRect(uint16_t px, uint16_t py, const Rect& r) {
  return px >= r.x && px < (r.x + r.w) && py >= r.y && py < (r.y + r.h);
}

