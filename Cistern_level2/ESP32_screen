// Touch actions fire on the initial press only, which prevents held touches
// from repeatedly activating the same control.
void handleTouchInput() {
  unsigned long now = millis();
  // Poll touch at a fixed cadence instead of every loop iteration.
  // This reduces I2C/display contention that can show up as tiny visual jitter.
  if (now - lastTouchPollMillis < TOUCH_POLL_INTERVAL_MS) {
    return;
  }
  lastTouchPollMillis = now;

  uint16_t x = 0;
  uint16_t y = 0;
  bool touched = touchAvailable && lcd.getTouch(&x, &y);
  if (touched) {
    touchX = x;
    touchY = y;
  }
  bool justPressed = touched && !touchPressed;
  touchPressed = touched;
  if (justPressed && (now - lastTouchActionMillis >= TOUCH_DEBOUNCE_MS)) {
    lastTouchActionMillis = now;
    handleTouchPress();
  }
}

// Wi-Fi is optional and non-blocking:
// scans run asynchronously and connection progress is polled from loop().
void updateWifiStateMachine() {
  unsigned long now = millis();
  if (now - lastWifiRefresh < WIFI_STATUS_REFRESH_MS) return;
  lastWifiRefresh = now;

  if (wifiScanInProgress) {
    int result = WiFi.scanComplete();
    if (result >= 0) {
      collectScanResults(result);
      if (currentPage == PAGE_WIFI_SELECT) {
        lcd.startWrite();
        updateWifiListArea(false);
        lcd.endWrite();
      }
    } else if (result == WIFI_SCAN_FAILED) {
      wifiScanInProgress = false;
      wifiActionMessage = "Network scan failed";
    }
  }

  wl_status_t status = WiFi.status();
  if (status == WL_CONNECTED) {
    wifiConnectInProgress = false;
    wifiActionMessage = "Connected to " + WiFi.SSID();
  } else if (wifiConnectInProgress && status == WL_CONNECT_FAILED) {
    wifiConnectInProgress = false;
    wifiActionMessage = "Connection failed";
  } else if (!wifiConnectInProgress && savedWifiSsid.length() == 0) {
    wifiActionMessage = "No saved Wi-Fi credentials";
  }

  String nextSummary = wifiSummaryLine();
  if (nextSummary != cachedWifiStateLine) {
    cachedWifiStateLine = nextSummary;
    if (currentPage == PAGE_WIFI) {
      lcd.startWrite();
      updateWifiStatusArea();
      updateWifiControlsArea();
      lcd.endWrite();
    } else if (currentPage == PAGE_WIFI_SELECT) {
      lcd.startWrite();
      updateWifiListArea(false);
      lcd.endWrite();
    }
  }
}

void setup() {
  pinMode(PIN_BACKLIGHT, OUTPUT);
  digitalWrite(PIN_BACKLIGHT, HIGH);
  Serial.begin(115200);
  // Keep HC-12 on a dedicated UART so boot/debug traffic on UART0 does not
  // get transmitted over the radio and show up as ERR UNKNOWN_CMD.
  HC12Serial.begin(9600, SERIAL_8N1, HC12_RX_PIN, HC12_TX_PIN);

  prefs.begin("cistern", false);
  loadCalibrationSettings();
  loadWiFiCredentials();
  refreshCalibrationPreview();

  Wire.begin(TOUCH_SDA_PIN, TOUCH_SCL_PIN, TOUCH_I2C_FREQ);
  touchAddress = detectGT911Address();
  touchAvailable = (touchAddress != 0);
  if (touchAvailable) lcd.configureTouch(touchAddress);

  lcd.init();
  lcd.setRotation(0);
  lcd.setTextWrap(false);

  if (savedWifiSsid.length() > 0) startWiFiConnection(savedWifiSsid, savedWifiPassword);
  else wifiActionMessage = "No saved Wi-Fi credentials";

  showCurrentPage();

  Serial.println("Ready for HC-12 data");
  if (touchAvailable) {
    Serial.print("GT911 touch detected at I2C address 0x");
    Serial.println(touchAddress, HEX);
  } else {
    Serial.println("GT911 touch not detected on 0x5D or 0x14");
  }
}

void loop() {
  unsigned long now = millis();

  while (HC12Serial.available()) {
    char c = (char)HC12Serial.read();
    if (c == '\n' || c == '\r') {
      if (rxLine.length() > 0) {
        lastRaw = rxLine;
        Serial.print("Received: ");
        Serial.println(lastRaw);
        if (parsePacket(lastRaw)) {
          hasValidPacket = true;
          lastPacketMillis = now;
          postCisternReading();
          if (currentPage == PAGE_DASHBOARD) updateDashboardData();
          else if (currentPage == PAGE_SETUP) {
            lcd.startWrite();
            updateSetupLiveSnapshot();
            lcd.endWrite();
          }
        } else {
          // Non-packet lines are typically command acknowledgements from the PCB.
          calibCommandResult = lastRaw;
          if (bridgeCommandPending) {
            postCommandResultToServer(bridgePendingCommandId, bridgePendingCommand, lastRaw, true);
            bridgeCommandPending = false;
            bridgePendingCommandId = "";
            bridgePendingCommand = "";
            bridgePendingCommandMillis = 0;
          }
          if (currentPage == PAGE_SETUP) {
            lcd.startWrite();
            updateSetupCommandArea();
            lcd.endWrite();
          }
        }
        rxLine = "";
      }
    } else {
      rxLine += c;
      if (rxLine.length() > 140) rxLine.remove(140);
    }
  }

  if (currentPage == PAGE_DASHBOARD && now - lastFooterRefresh >= FOOTER_REFRESH_MS) {
    lastFooterRefresh = now;
    String nextFooter = footerLineText();
    String nextHeader = headerStatusText();
    if (nextFooter != cachedFooterLine || nextHeader != cachedHeaderStatus) {
      lcd.startWrite();
      if (nextFooter != cachedFooterLine) updateFooterDynamic();
      if (nextHeader != cachedHeaderStatus) drawHeaderStatusPill();
      lcd.endWrite();
    }
  }

  if (currentPage == PAGE_SETUP && highlightedSetupButton != SETUP_BTN_NONE && now >= setupButtonHighlightUntil) {
    highlightedSetupButton = SETUP_BTN_NONE;
    lcd.startWrite();
    updateSetupCommandArea();
    lcd.endWrite();
  }

  if (bridgeCommandPending && now - bridgePendingCommandMillis >= SERVER_COMMAND_RESULT_TIMEOUT_MS) {
    postCommandResultToServer(bridgePendingCommandId, bridgePendingCommand, "TIMEOUT waiting for HC-12 reply", false);
    bridgeCommandPending = false;
    bridgePendingCommandId = "";
    bridgePendingCommand = "";
    bridgePendingCommandMillis = 0;
  }

  updateWifiStateMachine();
  pollServerForCommand();
  handleTouchInput();
}
