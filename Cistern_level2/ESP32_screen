String jsonEscape(const String& value) {
  String out;
  out.reserve(value.length() + 8);

  for (size_t i = 0; i < value.length(); ++i) {
    char c = value[i];
    switch (c) {
      case '\\': out += "\\\\"; break;
      case '"':  out += "\\\""; break;
      case '\n': out += "\\n"; break;
      case '\r': out += "\\r"; break;
      case '\t': out += "\\t"; break;
      default:   out += c; break;
    }
  }

  return out;
}

String jsonGetString(const String& json, const String& key) {
  String needle = "\"" + key + "\":\"";
  int start = json.indexOf(needle);
  if (start < 0) return "";
  start += needle.length();

  String out = "";
  bool escaped = false;
  for (int i = start; i < json.length(); ++i) {
    char c = json[i];
    if (escaped) {
      switch (c) {
        case 'n': out += '\n'; break;
        case 'r': out += '\r'; break;
        case 't': out += '\t'; break;
        default: out += c; break;
      }
      escaped = false;
      continue;
    }
    if (c == '\\') {
      escaped = true;
      continue;
    }
    if (c == '"') break;
    out += c;
  }
  return out;
}

bool jsonGetBool(const String& json, const String& key, bool defaultValue) {
  String trueNeedle = "\"" + key + "\":true";
  if (json.indexOf(trueNeedle) >= 0) return true;
  String falseNeedle = "\"" + key + "\":false";
  if (json.indexOf(falseNeedle) >= 0) return false;
  return defaultValue;
}

bool postCisternReading() {
  // Cloud posting is optional. The local screen and HC-12 path keep working
  // even if Wi-Fi is down or the Flask server is unavailable.
  if (!cloudReady()) {
    lastPostSuccess = false;
    lastPostHttpCode = 0;
    return false;
  }

  if (!hasValidPacket) {
    lastPostSuccess = false;
    lastPostHttpCode = 0;
    return false;
  }

  unsigned long now = millis();
  bool valuesChanged =
    (fabsf(levelPct - lastPostedLevelPct) > 0.05f) ||
    (gallons != lastPostedGallons) ||
    (adcValue != lastPostedAdc) ||
    (calibrated != lastPostedCalibrated);

  bool intervalElapsed = (lastPostMillis == 0) || (now - lastPostMillis >= SERVER_POST_INTERVAL_MS);
  if (!valuesChanged && !intervalElapsed) {
    return false;
  }

  WiFiClient client;
  HTTPClient http;

  Serial.print("POST URL: ");
  Serial.println(SERVER_URL);

  if (!http.begin(client, SERVER_URL)) {
    Serial.println("POST failed: http.begin() failed");
    lastPostSuccess = false;
    lastPostHttpCode = -1;
    return false;
  }

  http.setTimeout(SERVER_POST_TIMEOUT_MS);
  http.addHeader("Content-Type", "application/json");

  String payload = "{";
  payload += "\"device_id\":\"" + jsonEscape(String(DEVICE_ID)) + "\",";
  payload += "\"level_pct\":" + String(levelPct, 1) + ",";
  payload += "\"gallons\":" + String(gallons) + ",";
  payload += "\"adc\":" + String(adcValue) + ",";
  payload += "\"calibrated\":";
  payload += (calibrated ? "true" : "false");
  payload += ",";
  payload += "\"raw\":\"" + jsonEscape(lastRaw) + "\"";
  payload += "}";

  int httpCode = http.POST(payload);
  lastPostMillis = now;
  lastPostHttpCode = httpCode;
  lastPostSuccess = (httpCode >= 200 && httpCode < 300);

  if (lastPostSuccess) {
    lastPostedLevelPct = levelPct;
    lastPostedGallons = gallons;
    lastPostedAdc = adcValue;
    lastPostedCalibrated = calibrated;
    Serial.print("POST success, HTTP code: ");
    Serial.println(httpCode);
  } else {
    Serial.print("POST failed, HTTP code: ");
    Serial.println(httpCode);
    if (httpCode <= 0) {
      Serial.print("POST error: ");
      Serial.println(http.errorToString(httpCode));
    }
  }

  http.end();
  return lastPostSuccess;
}

bool postCommandResultToServer(const String& cmdId, const String& cmd, const String& result, bool ok) {
  if (!cloudReady() || cmdId.length() == 0) return false;

  WiFiClient client;
  HTTPClient http;
  if (!http.begin(client, SERVER_COMMAND_RESULT_URL)) {
    Serial.println("Command result POST failed: http.begin() failed");
    return false;
  }

  http.setTimeout(SERVER_POST_TIMEOUT_MS);
  http.addHeader("Content-Type", "application/json");

  String payload = "{";
  payload += "\"device_id\":\"" + jsonEscape(String(DEVICE_ID)) + "\",";
  payload += "\"cmd_id\":\"" + jsonEscape(cmdId) + "\",";
  payload += "\"cmd\":\"" + jsonEscape(cmd) + "\",";
  payload += "\"result\":\"" + jsonEscape(result) + "\",";
  payload += "\"ok\":";
  payload += (ok ? "true" : "false");
  payload += "}";

  int httpCode = http.POST(payload);
  bool success = (httpCode >= 200 && httpCode < 300);
  Serial.print("Command result POST HTTP code: ");
  Serial.println(httpCode);
  http.end();
  return success;
}

void pollServerForCommand() {
  if (!cloudReady() || bridgeCommandPending) return;

  unsigned long now = millis();
  if (now - lastCommandPollMillis < SERVER_COMMAND_POLL_INTERVAL_MS) return;
  lastCommandPollMillis = now;

  WiFiClient client;
  HTTPClient http;
  String url = String(SERVER_COMMAND_URL) + "?device_id=" + String(DEVICE_ID);

  if (!http.begin(client, url)) {
    Serial.println("Command poll skipped: http.begin() failed");
    return;
  }

  http.setTimeout(SERVER_POST_TIMEOUT_MS);
  int httpCode = http.GET();
  Serial.print("Command poll HTTP code: ");
  Serial.println(httpCode);

  if (httpCode >= 200 && httpCode < 300) {
    String body = http.getString();
    bool pending = jsonGetBool(body, "pending", false);
    if (pending) {
      String cmdId = jsonGetString(body, "cmd_id");
      String cmd = jsonGetString(body, "cmd");
      if (cmdId.length() > 0 && cmd.length() > 0) {
        bridgeCommandPending = true;
        bridgePendingCommandId = cmdId;
        bridgePendingCommand = cmd;
        bridgePendingCommandMillis = now;
        Serial.print("Dispatching bridged command: ");
        Serial.println(cmd);
        issueCalibrationCommand(cmd);
      }
    }
  }

  http.end();
}

void startWiFiConnection(const String& ssid, const String& password) {
  if (ssid.length() == 0) {
    wifiActionMessage = "No saved Wi-Fi credentials";
    wifiConnectInProgress = false;
    return;
  }
  WiFi.mode(WIFI_STA);
  WiFi.setAutoReconnect(true);
  WiFi.begin(ssid.c_str(), password.c_str());
  wifiConnectInProgress = true;
  wifiActionMessage = "Connecting to " + ssid;
}

void beginWifiScan() {
  WiFi.mode(WIFI_STA);
  WiFi.scanDelete();
  int result = WiFi.scanNetworks(true, true);
  wifiScanInProgress = (result == WIFI_SCAN_RUNNING);
  scanNetworkCount = 0;
  wifiActionMessage = wifiScanInProgress ? "Scanning for networks..." : "Failed to start scan";
}

void forgetWifiAction() {
  WiFi.disconnect(true, true);
  clearWiFiCredentials();
  wifiConnectInProgress = false;
  wifiActionMessage = "Saved Wi-Fi forgotten";
}

void collectScanResults(int resultCount) {
  scanNetworkCount = min(resultCount, MAX_SCAN_NETWORKS);
  for (int i = 0; i < scanNetworkCount; ++i) {
    scanSsids[i] = WiFi.SSID(i);
    scanRssi[i] = WiFi.RSSI(i);
    scanOpen[i] = (WiFi.encryptionType(i) == WIFI_AUTH_OPEN);
  }
  WiFi.scanDelete();
  wifiScanInProgress = false;
  wifiActionMessage = (scanNetworkCount > 0) ? "Select a network to continue" : "No networks found";
}

