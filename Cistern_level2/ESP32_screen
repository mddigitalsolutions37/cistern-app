String lastUpdateText() {
  if (!hasValidPacket) return "Awaiting first packet";
  unsigned long ageMs = millis() - lastPacketMillis;
  if (ageMs < 1000UL) return "Updated just now";
  unsigned long seconds = ageMs / 1000UL;
  if (seconds < 60UL) return "Updated " + String(seconds) + "s ago";
  unsigned long minutes = seconds / 60UL;
  return "Updated " + String(minutes) + "m ago";
}

