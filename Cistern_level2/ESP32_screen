void openCalibEntry(CalibEntryField field) {
  activeCalibEntryField = field;
  switch (field) {
    case CALIB_ENTRY_TANK_HEIGHT: calibEntryBuffer = String(calibTankHeightFt, 1); break;
    case CALIB_ENTRY_TANK_FULL: calibEntryBuffer = String((int)roundf(calibTankFullGal)); break;
    case CALIB_ENTRY_DOWN_FT: calibEntryBuffer = String(calibDownFt); break;
    case CALIB_ENTRY_DOWN_IN: calibEntryBuffer = String(calibDownIn); break;
    default: calibEntryBuffer = ""; break;
  }
  lcd.startWrite();
  updateSetupFieldArea();
  drawCalibEntryModal();
  lcd.endWrite();
}

void closeCalibEntry() {
  activeCalibEntryField = CALIB_ENTRY_NONE;
  calibEntryBuffer = "";
  drawSetupPage();
  updateSetupPageDynamic();
}

void applyCalibEntry() {
  if (activeCalibEntryField == CALIB_ENTRY_NONE || calibEntryBuffer.length() == 0) {
    closeCalibEntry();
    return;
  }

  switch (activeCalibEntryField) {
    case CALIB_ENTRY_TANK_HEIGHT:
      calibTankHeightFt = constrain(calibEntryBuffer.toFloat(), 1.0f, 20.0f);
      saveCalibrationSettings();
      break;
    case CALIB_ENTRY_TANK_FULL:
      calibTankFullGal = constrain(calibEntryBuffer.toFloat(), 100.0f, 20000.0f);
      saveCalibrationSettings();
      break;
    case CALIB_ENTRY_DOWN_FT:
      calibDownFt = constrain(calibEntryBuffer.toInt(), 0, 20);
      break;
    case CALIB_ENTRY_DOWN_IN:
      calibDownIn = constrain(calibEntryBuffer.toInt(), 0, 11);
      break;
    default:
      break;
  }

  refreshCalibrationPreview();
  calibResultMessage = "Value updated";
  closeCalibEntry();
}

